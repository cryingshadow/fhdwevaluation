\NeedsTeXFormat{LaTeX2e}[1994/06/01]
\ProvidesPackage{fhdwevaluation}[2022/09/16 LaTeX Evaluation Package for FHDW]

\DeclareOption*{
 \PackageWarning{fhdwevaluation}{Unknown option '\CurrentOption'}
}

\ProcessOptions\relax

\RequirePackage[ngerman]{babel}
\RequirePackage[T1]{fontenc}
\RequirePackage{ifthen}
\RequirePackage{etoolbox}

\newcounter{evaluationtotal}
\setcounter{evaluationtotal}{100}
\newcounter{evaluationcounter}
\setcounter{evaluationcounter}{0}
\newcounter{evaluationpercent}
\setcounter{evaluationpercent}{0}
\newcounter{evaluationpartcounter}
\setcounter{evaluationpartcounter}{0}

\newboolean{unused}
\setboolean{unused}{false}

\newboolean{pointswarning}
\setboolean{pointswarning}{true}

\newcommand{\gradetext}{%
\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<50\relax%
5,0%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<59\relax%
4,0%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<67\relax%
3,7%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<72\relax%
3,3%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<77\relax%
3,0%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<81\relax%
2,7%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<85\relax%
2,3%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<89\relax%
2,0%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<92\relax%
1,7%
\else\ifnum\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}<97\relax%
1,3%
\else%
1,0%
\fi\fi\fi\fi\fi\fi\fi\fi\fi\fi
\ifthenelse{\boolean{pointswarning}}{%
\ifboolexpr{%
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{47}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{48}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{49}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{58}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{66}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{71}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{76}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{80}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{84}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{88}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{91}} or 
test {\ifnumcomp{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}{=}{96}}
}{\footnote{\textcolor{red}{Ergebnis ist grenzwertig!}}}{}%
}{}%
}
\newcommand{\grade}{\begin{center}{\large\textbf{\gradetext}}\end{center}}
\newcommand{\evaluation}[2]{\ifnotempty{#1}{\addtocounter{evaluationcounter}{#1}\begin{flushright}{Bewertung: #1 von #2 Punkten}\end{flushright}}}
\newcommand{\evaluationpartresult}[1]{\evaluation{\arabic{evaluationpartcounter}}{#1}\setcounter{evaluationpartcounter}{0}}
\newcommand{\addevaluation}[1]{\addtocounter{evaluationcounter}{#1}}
\newcommand{\addevaluationpart}[1]{\addtocounter{evaluationpartcounter}{#1}}
\newcommand{\evaluationpoints}{\arabic{evaluationcounter}}
\newcommand{\evaluationpercent}{\setcounter{evaluationpercent}{\numexpr100*\value{evaluationcounter}/\value{evaluationtotal}}\arabic{evaluationpercent}\%}
\newcommand{\ifnotempty}[2]{%
\if\relax\detokenize{#1}\relax
\setboolean{unused}{true}
\else%
#2%
\fi%
}
\newcommand{\orelse}[2]{%
\if\relax\detokenize{#1}\relax
#2%
\else%
#1%
\fi%
}
